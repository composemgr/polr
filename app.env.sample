# Polr URL Shortener — environment variable reference
# Copy relevant lines to a .env file alongside docker-compose.yaml

# Timezone
TZ=America/New_York

# Hostname / domain
BASE_HOST_NAME=${HOSTNAME}
BASE_DOMAIN_NAME=example.com
APP_PROTOCOL=https

# Application
APP_NAME=Polr
APP_SECRET_KEY=changeme_secret_key_min_32_chars

# Admin credentials (used on first setup)
APP_ADMIN_USER=admin
APP_ADMIN_PASS=changeme_admin_password
APP_ADMIN_EMAIL=admin@example.com

# Database
DB_CREATE_DATABASE_NAME=polr
DB_USER_NAME=polr
DB_USER_PASS=changeme_db_password
DB_ADMIN_PASS=changeme_admin_password

# Registration / public access
PUBLIC_INTERFACE=false
ALLOW_REGISTRATION=false
